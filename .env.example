# --- NextAuth core ---
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
# Your deployed URL, e.g. https://your-app.vercel.app (not needed on Vercel prod, but useful locally)
NEXTAUTH_URL=http://localhost:3000

# --- Google OAuth (Google Cloud Console > APIs & Services > Credentials) ---
# Authorized redirect URI: <your-url>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Comma-separated list of Google account emails allowed to sign in.
# Leave empty to allow any Google account (not recommended for a private tool).
ALLOWED_EMAILS=you@example.com,teammate@example.com

# --- Simple admin login (used on the "Sign in" form, no Google needed) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# --- Vercel Blob storage ---
# Create a Blob store in your Vercel project (Storage tab), then copy its token here.
# Locally, run `vercel env pull .env.local` after linking the project to fetch this automatically.
BLOB_READ_WRITE_TOKEN=
